# ─────────── Aurora Edge Dashboard v3 — environment ───────────
# SECURITY: ADMIN_PASSWORD must be set on first run.
# If not set, a random one is generated and logged (check logs once).
ADMIN_PASSWORD=
ADMIN_PATH=manage
SESSION_TTL_HOURS=2
SESSION_IDLE_TTL_MINUTES=30
PORT=8080
MASTER_UUID=
PUBLIC_HOST=

REALITY_DEST=www.cloudflare.com:443
# v3.2: For best ping in Iran, try alternative dest options:
#   www.microsoft.com:443     (Azure CDN, very stable)
#   www.apple.com:443         (Apple CDN, low latency)
#   www.tesla.com:443         (Cloudflare CDN)
#   www.samsung.com:443       (Akamai CDN)
# Choose one that's not blocked by your ISP and has a nearby PoP.
XRAY_VERSION=v25.3.6

# gRPC transport path (serviceName)
GRPC_PATH=/grpc

# v3.3: Extra WS ports (comma-separated) for users whose ISP blocks 443
# These listen directly on Xray (plain WS, no TLS — use Reality for TLS).
# Railway must TCP-proxy these ports. Default: 2083
EXTRA_WS_PORTS=2083

# GitHub State Sync
GH_TOKEN=
GH_REPO=be2be22/s
GH_BRANCH=main
GH_DATA_DIR=state
GH_SYNC_SECONDS=90

# Axiom Logs (Zero-Disk Logging)
AXIOM_TOKEN=
AXIOM_DATASET=aurora-logs
AXIOM_CACHE_TTL=60

# Telegram
TG_BOT_TOKEN=
TG_ADMIN_ID=
TG_WEBHOOK_SECRET=
TG_WEBHOOK_CONCURRENCY=5

# Performance tuning (optional, defaults shown)
SAMPLE_SECS=10
ONLINE_WINDOW=30
HISTORY_LEN=60
MAX_TRACKED_IPS=500
IP_LOG_MAX_BYTES=1048576
